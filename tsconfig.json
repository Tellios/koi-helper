{
  "extends": "@electron-toolkit/tsconfig/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react",
    "baseUrl": ".",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@app/*": [
        "src/app/*"
      ],
    }
  },
  "include": [
    "src/**/*",
  ]
}
