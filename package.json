{
  "name": "tellios-koi-helper",
  "version": "0.0.6",
  "description": "Application for helping you with saving data about your koi fish",
  "main": "main.js",
  "author": "Sonny Johannesson",
  "license": "MIT",
  "owner": "Tellios",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tellios/koi-helper.git"
  },
  "scripts": {
    "lint": "prettier --write . && eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.tellios.koi.helper",
    "productName": "Koi Helper",
    "artifactName": "KoiHelper-${version}.${ext}",
    "win": {
      "publish": [
        "github"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Tellios"
    },
    "files": [
      {
        "from": "src",
        "to": "dist"
      }
    ]
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-toastify": "^4.1.0",
    "@types/recharts": "^2.0.1",
    "@types/sharp": "^0.32.0",
    "@types/sqlite3": "^5.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.1",
    "aws-sdk": "^2.1692.0",
    "circular-dependency-plugin": "^5.2.2",
    "concurrently": "^9.1.2",
    "css-loader": "^7.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "overmind-devtools": "^29.1.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/x-date-pickers": "^8.5.1",
    "chokidar": "^4.0.3",
    "date-fns": "^4.1.0",
    "env-paths": "^3.0.0",
    "formik": "^2.4.6",
    "formik-mui": "^5.0.0-alpha.1",
    "fs-extra": "^11.3.0",
    "i18n-ts": "^1.0.5",
    "inversify": "^7.5.2",
    "lodash": "^4.17.21",
    "normalize.css": "^8.0.1",
    "overmind": "^28.0.4",
    "overmind-react": "^29.0.6",
    "p-limit": "^6.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intersection-observer": "^9.16.0",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.6.2",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.3",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.2",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "tempy": "^3.1.0",
    "typeface-roboto": "1.1.13",
    "typeorm": "^0.3.24",
    "winston": "^3.17.0",
    "yup": "^1.6.1"
  }
}
