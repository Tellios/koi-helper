{
  "name": "tellios-koi-helper",
  "version": "0.0.6",
  "description": "Application for helping you with saving data about your koi fish",
  "main": ".webpack/main",
  "author": "Sonny Johannesson",
  "license": "MIT",
  "owner": "Tellios",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tellios/koi-helper.git"
  },
  "scripts": {
    "postinstall": "npx electron-rebuild -f -w sqlite3",
    "lint": "prettier --write . && eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "build": "electron-forge make",
    "build:windows-x64": "npm run build -- --arch=x64 --platform=win32",
    "build:linux-x64": "npm run build -- --arch=x64 --platform=linux"
  },
  "build": {
    "appId": "com.tellios.koi.helper",
    "productName": "Koi Helper",
    "artifactName": "KoiHelper-${version}.${ext}",
    "win": {
      "publish": [
        "github"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Tellios"
    },
    "files": [
      {
        "from": "src",
        "to": "dist"
      }
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/fuses": "^1.8.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-toastify": "^4.1.0",
    "@types/recharts": "^2.0.1",
    "@types/sharp": "^0.32.0",
    "@types/sqlite3": "^5.1.0",
    "@types/uuid": "^10.0.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "circular-dependency-plugin": "^5.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^40.6.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "node-loader": "^2.1.0",
    "overmind-devtools": "^29.1.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/x-date-pickers": "^8.5.1",
    "chokidar": "^4.0.3",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "env-paths": "^3.0.0",
    "formik": "^2.4.6",
    "formik-mui": "^5.0.0-alpha.1",
    "fs-extra": "^11.3.0",
    "i18n-ts": "^1.0.5",
    "inversify": "^7.5.2",
    "lodash": "^4.17.21",
    "node-abi": "^4.26.0",
    "normalize.css": "^8.0.1",
    "overmind": "^28.0.4",
    "overmind-react": "^29.0.6",
    "p-limit": "^6.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intersection-observer": "^9.16.0",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.6.2",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.3",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "tempy": "^3.1.0",
    "typeface-roboto": "1.1.13",
    "typeorm": "^0.3.24",
    "winston": "^3.17.0",
    "yup": "^1.6.1"
  }
}
